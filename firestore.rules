rules_version = '2';

// NexaPOS multi-branch security rules.
// Every business's data lives under businesses/{businessId}, where businessId is
// the Firebase Auth uid of that business's single shared account. A signed-in
// account can read and write ONLY its own business subtree — no business can ever
// see another's data. Branch-vs-branch visibility is enforced in the app (all of
// a business's devices share one account); this is the hard isolation boundary.
service cloud.firestore {
  match /databases/{database}/documents {
    match /businesses/{businessId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == businessId;
    }
  }
}
